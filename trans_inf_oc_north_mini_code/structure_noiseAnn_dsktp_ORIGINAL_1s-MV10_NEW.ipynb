    "@numba.njit\n",
    "def duplicates(dbins):\n",
    "    dup = 0\n",
    "    for iii in range(len(dbins)):\n",
    "        for jjj in range(len(dbins)):\n",
    "            if iii != jjj:\n",
    "                if (dbins[iii][0] == dbins[jjj][0]) & (dbins[iii][1] == dbins[jjj][1]):\n",
    "                    dup = 1\n",
    "    return dup\n",
    "\n",
    "# function to check how many runs had duplicate bins\n",
    "@numba.njit\n",
    "def runs_dup_bins(runs, fsigweights, t):\n",
    "    dup_count = 0\n",
    "    for i0 in range(runs):\n",
    "        sw = fsigweights[i0].copy()\n",
    "        swl = sw.argmax(axis=3)[0, 0]\n",
    "        swr = sw.argmax(axis=3)[0, 1]\n",
    "        bns = np.zeros(((2*(t-1)), 2), dtype = numba.int64)\n",
    "        for idx000 in range(t-1):\n",
    "            bns[idx000][0] = swl[idx000] \n",
    "            bns[idx000][1] = swr[idx000+1]\n",
    "        for idx001 in range(t-1):\n",
    "            bns[t-1+idx001][0] = swl[idx001+1] \n",
    "            bns[t-1+idx001][1] = swr[idx001]\n",
    "        dup_count += duplicates(bns)\n",
    "    return dup_count\n",
    "\n",
    "# function to check how many runs had duplicate bins\n",
    "@numba.njit\n",
    "def make_circular_pairs(n_stim):\n",
    "    \"\"\"\n",
    "    Generate pairs for a circular ordering of stimuli.\n",
    "    For a pair x, y with y>x, let d_x = y - x, let d_y = (x - y) % n_stim.\n",
    "    Reward y if d_x < d_y and reward x if d_x > d_y.\n",
    "    E.g. with n_stim = 7 then for x = 0 and y = 3 the shortest sequence on the circle between the two is 0, 1, 2, 3 but if instead we have x = 0 and y = 4, then the shortest sequence is 4, 5, 6, 0 making 0 the \"rightmost\" element in the sequence.\n",
    "    Returns: adjpairs, adjpairs_reward, nonadjpairs, nonadjpairs_reward, testpairs, testpairs_reward\n",
    "    \"\"\"\n",
    "    pairs = np.array([(i, j) for i in range(n_stim) for j in range(n_stim) if i != j], dtype=np.int64)\n",
    "    pairs_reward = np.zeros((len(pairs), 2), dtype=np.int64)\n",
    "    \n",
    "    for idx, (x, y) in enumerate(pairs):\n",
    "        d_x = (y - x) % n_stim\n",
    "        d_y = (x - y) % n_stim\n",
    "        if d_x < d_y:\n",
    "            # y is rightmost (reward y)\n",
    "            pairs_reward[idx] = [0, 1]\n",
    "        else:\n",
    "            # x is rightmost (reward x)\n",
    "            pairs_reward[idx] = [1, 0]\n",
    "    \n",
    "    # Split into adjacent, non-adjacent, and test pairs\n",
    "    # Adjacent pairs have distance 1 on the circle\n",
    "    adj_mask = np.zeros(len(pairs), dtype=bool)\n",
    "    for idx, (x, y) in enumerate(pairs):\n",
    "        d = min((y - x) % n_stim, (x - y) % n_stim)\n",
    "        if d == 1:\n",
    "            adj_mask[idx] = True\n",
    "    \n",
    "    adjpairs = pairs[adj_mask]\n",
    "    adjpairs_reward = pairs_reward[adj_mask]\n",
    "    \n",
    "    # Non-adjacent pairs\n",
    "    nonadj_mask = ~adj_mask\n",
    "    nonadjpairs = pairs[nonadj_mask]\n",
    "    nonadjpairs_reward = pairs_reward[nonadj_mask]\n",
    "    \n",
    "    # Test pairs: the most distant pairs (distance floor(n_stim/2))\n",
    "    # For odd n_stim, pick the single pair with maximum distance\n",
    "    max_dist = n_stim // 2\n",
    "    test_mask = np.zeros(len(pairs), dtype=bool)\n",
    "    for idx, (x, y) in enumerate(pairs):\n",
    "        d = min((y - x) % n_stim, (x - y) % n_stim)\n",
    "        if d == max_dist:\n",
    "            test_mask[idx] = True\n",
    "    \n",
    "    testpairs = pairs[test_mask]\n",
    "    testpairs_reward = pairs_reward[test_mask]\n",
    "    \n",
    "    return adjpairs, adjpairs_reward, nonadjpairs, nonadjpairs_reward, testpairs, testpairs_reward\n",
    "\n",
    "# Test the circular pairs generator with n_stim = 7\n",
    "adjpairs7, adjpairs_reward7, nonadjpairs7, nonadjpairs_reward7, testpairs7, testpairs_reward7 = make_circular_pairs(7)\n",
    "\n",
    "print(f'terms = 7')\n",
    "print(f'adjacent pairs: {len(adjpairs7)}')\n",
    "print(f'non-adjacent pairs: {len(nonadjpairs7)}')\n",
    "print(f'test pairs: {len(testpairs7)}')\n",
    "print(f'Sample adjacent pair (0,1): reward = {adjpairs_reward7[1]}')\n",
    "print(f'Sample test pair (0,3): reward = {testpairs_reward7[1]}')\n",
    "\n",
    "@numba.njit\n",
    "def pairs_distance_from_circle(n_stim, x, y):\n",
    "    \"\"\"Return the minimum distance between x and y on a circle of size n_stim.\n",
    "    For example, with n_stim = 7:\n",
    "    - distance(0, 3) = 3 (sequence: 0, 1, 2, 3)\n",
    "    - distance(0, 4) = 3 (sequence: 4, 5, 6, 0)\n",
    "    \"\"\"\n",
    "    d_forward = (y - x) % n_stim\n",
    "    d_backward = (x - y) % n_stim\n",
    "    return min(d_forward, d_backward)\n",
    "\n",
    "@numba.njit\n",
    "def pairs_endpoint_on_circle(n_stim, x, y):\n",
    "    \"\"\"Return (min(x,y), max(x,y)) for circular analysis.\n",
    "    This helps identify serial position effects.\n",
    "    \"\"\"\n",
    "    return (min(x, y), max(x, y))\n",
    "\n",
    "@numba.njit\n",
    "def aggregate_pair_stats_by_distance(pair_stats, testpairs, n_stim, terms):\n",
    "    \"\"\"Aggregate pair_stats by circular distance for distance effect analysis.\n",
    "    Returns dict mapping distance -> (total_attempts, total_successes).\n",
    "    \"\"\"\n",
    "    distance_stats = {}\n",
    "    for d in range(1, terms//2 + 1):\n",
    "        distance_stats[d] = [0, 0]  # [attempts, successes]\n",
    "    \n",
    "    for idx in range(len(testpairs)):\n",
    "        attempts, successes = pair_stats[idx]\n",
    "        x, y = testpairs[idx]\n",
    "        distance = pairs_distance_from_circle(n_stim, x, y)\n",
    "        if distance in distance_stats:\n",
    "            distance_stats[distance][0] += attempts\n",
    "            distance_stats[distance][1] += successes\n",
    "    \n",
    "    # Convert to arrays for easier post-processing\n",
    "    distances = np.array(list(distance_stats.keys()))\n",
    "    attempts_by_distance = np.array([distance_stats[d][0] for d in distances])\n",
    "    successes_by_distance = np.array([distance_stats[d][1] for d in distances])\n",
    "    \n",
    "    return distances, attempts_by_distance, successes_by_distance\n",
    "\n",
    "@numba.njit\n",
    "def aggregate_pair_stats_by_endpoint(pair_stats, testpairs):\n",
    "    \"\"\"Aggregate pair_stats by endpoints for serial position analysis.\n",
    "    Returns dict mapping (min, max) -> (total_attempts, total_successes).\n",
    "    \"\"\"\n",
    "    endpoint_stats = {}\n",
    "    for idx in range(len(testpairs)):\n",
    "        x, y = testpairs[idx]\n",
    "        low, high = (x, y) if x < y else (y, x)\n",
    "        endpoint_stats[(low, high)] = [0, 0]\n",
    "    \n",
    "    for idx in range(len(testpairs)):\n",
    "        attempts, successes = pair_stats[idx]\n",
    "        x, y = testpairs[idx]\n",
    "        low, high = (x, y) if x < y else (y, x)\n",
    "        endpoint_stats[(low, high)][0] += attempts\n",
    "        endpoint_stats[(low, high)][1] += successes\n",
    "    \n",
    "    # Convert to arrays for easier post-processing\n",
    "    endpoints = np.array(list(endpoint_stats.keys()))\n",
    "    attempts_by_endpoint = np.array([endpoint_stats[ep][0] for ep in endpoints])\n",
    "    successes_by_endpoint = np.array([endpoint_stats[ep][1] for ep in endpoints])\n",
    "    \n",
    "    return endpoints, attempts_by_endpoint, successes_by_endpoint\n",
    "\n",
    "print(\"\"\"Distance effect analysis setup complete!
",
    "The modified code now supports:\n",
    "1. Dynamic reward specification via reward arrays\n",
    "2. Circular ordering via make_circular_pairs function\n",
    "3. Per-pair success tracking via pair_stats\n",
    "4. Distance and serial position effect analysis\n",
    "\"\"\")\n"
   ]
  }
